# ─── Yelp Fusion API ─────────────────────────────────────────────
# Get your key at: https://www.yelp.com/developers → Create App
YELP_API_KEY=your_yelp_fusion_api_key_here

# ─── Anthropic API (Claude AI – for specials extraction) ─────────
# Get your key at: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your_anthropic_key_here

# ─── Server Config ────────────────────────────────────────────────
PORT=3001

# ─── Cache Settings ──────────────────────────────────────────────
# How long to cache Yelp results in milliseconds
# 3600000 = 1 hour | 86400000 = 24 hours (Yelp's max allowed)
CACHE_TTL_MS=3600000

# ─── Milwaukee County Search Settings ────────────────────────────
MKE_LATITUDE=43.0389
MKE_LONGITUDE=-87.9065
MKE_RADIUS_METERS=25000

# ─── CORS ─────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (your frontend URL)
# Use * for development only — lock this down in production!
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:5500
